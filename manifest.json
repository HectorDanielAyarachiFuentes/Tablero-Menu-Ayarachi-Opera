{
  "manifest_version": 3,
  "name": "Tablero",
  "version": "3.0.1",
  "description": "Un tablero personalizable para tu página de nueva pestaña con gestión de notas.",
  
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "64": "icons/icon.svg",
    "128": "icons/icon.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tablero-hector@ayarachi.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },

  "background": {
    "service_worker": "menubar/background.js"
  },

  "action": {
    "default_title": "Tablero",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "64": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },

  "permissions": [
    "storage",
    "geolocation",
    "bookmarks",
    "unlimitedStorage",
    "tabs"
  ],

  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data: https://* https://www.google.com https://google.com https://t3.gstatic.com blob: moz-extension:;"
  },

  "web_accessible_resources": [
    {
      "resources": ["menubar/system/file-worker.js"],
      "matches": ["<all_urls>"]
    }
  ]
}